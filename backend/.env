# ─── SiteForge AI — Local Development Environment ──────────────────────────
# Copy this file to .env and update values as needed

# General
NODE_ENV=development
JWT_SECRET=siteforge-dev-jwt-secret-change-in-production-min-32-chars

# PostgreSQL
POSTGRES_PASSWORD=siteforge-dev

# Redis
REDIS_PASSWORD=

# MinIO (local S3)
MINIO_ROOT_USER=siteforge
MINIO_ROOT_PASSWORD=siteforge-secret
S3_BUCKET=siteforge-assets

# AI (optional for full AI features)
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Payment Providers (optional for payment features)
STRIPE_SECRET_KEY=sk_test_your-stripe-test-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret

# Email (optional)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=

# CORS - frontend URL
CORS_ORIGINS=http://localhost:5173
