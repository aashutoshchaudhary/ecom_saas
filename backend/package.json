{
  "name": "siteforge-backend",
  "private": true,
  "version": "1.0.0",
  "description": "SiteForge AI - Microservices Backend",
  "workspaces": [
    "shared",
    "services/*"
  ],
  "scripts": {
    "dev": "docker compose up -d",
    "dev:stop": "docker compose down",
    "build": "npm run build --workspaces --if-present",
    "lint": "eslint . --ext .ts",
    "test": "jest --passWithNoTests",
    "migrate": "npm run migrate --workspaces --if-present",
    "seed": "npm run seed --workspaces --if-present",
    "clean": "rm -rf services/*/dist shared/dist"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "eslint": "^9.5.0",
    "jest": "^29.7.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
