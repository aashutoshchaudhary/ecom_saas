generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DomainType {
  SUBDOMAIN
  CUSTOM
}

enum DomainStatus {
  PENDING
  ACTIVE
  FAILED
  EXPIRED
}

enum SslStatus {
  PENDING
  ACTIVE
  FAILED
}

model Domain {
  id         String       @id @default(cuid())
  tenantId   String
  websiteId  String
  domain     String       @unique
  type       DomainType   @default(SUBDOMAIN)
  status     DomainStatus @default(PENDING)
  sslStatus  SslStatus    @default(PENDING)
  dnsRecords Json         @default("[]")
  verifiedAt DateTime?
  expiresAt  DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
}
