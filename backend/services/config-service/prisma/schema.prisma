generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ServiceConfig {
  id        String   @id @default(cuid())
  service   String
  key       String
  value     Json
  isSecret  Boolean  @default(false)
  updatedAt DateTime @updatedAt

  @@unique([service, key])
}

model FeatureFlag {
  id        String   @id @default(cuid())
  name      String   @unique
  enabled   Boolean  @default(false)
  tenants   String[]
  config    Json     @default("{}")
  updatedAt DateTime @updatedAt
}
