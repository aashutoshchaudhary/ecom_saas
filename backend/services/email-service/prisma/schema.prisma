generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model EmailTemplate {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  subject   String
  body      String
  variables String[]

  @@unique([tenantId, name])
}

model EmailLog {
  id         String    @id @default(cuid())
  tenantId   String
  to         String
  subject    String
  templateId String?
  status     String    @default("QUEUED")
  provider   String    @default("SES")
  sentAt     DateTime?
  error      String?
  createdAt  DateTime  @default(now())
}
